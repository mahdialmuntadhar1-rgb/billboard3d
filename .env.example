# Frontend Environment Variables for Billboard3D

# 🟢 LOCAL DEVELOPMENT
# When running backend locally with Wrangler:
VITE_API_URL=http://localhost:8787
VITE_USE_MOCK_API=false

# 🟢 PRODUCTION (Cloudflare Worker)
# After deploying your Cloudflare Worker, update this URL:
# Format: https://your-worker-name.your-subdomain.workers.dev
# Example: https://billboard3d-api.your-account.workers.dev
VITE_API_URL=https://billboard3d-api.your-account.workers.dev
VITE_USE_MOCK_API=false

# 🧪 MOCK MODE (for development without backend)
# Set to true to use fake/mock data instead of real API
VITE_USE_MOCK_API=true

# ⚠️ IMPORTANT NOTES:
# - All Vite environment variables MUST start with VITE_
# - Use .env.local for local development (gitignored)
# - Use .env.production for production builds
# - Never commit actual .env files with secrets
